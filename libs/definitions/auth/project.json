{
  "name": "definitions-auth",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/definitions/auth/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/definitions/auth",
        "main": "libs/definitions/auth/src/index.ts",
        "tsConfig": "libs/definitions/auth/tsconfig.lib.json",
        "assets": ["libs/definitions/auth/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/definitions/auth/**/*.ts",
          "libs/definitions/auth/package.json"
        ]
      }
    }
  },
  "tags": []
}
