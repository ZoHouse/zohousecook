# PMS App — Environment Variables
# Copy this file to .env.local and fill in the values

# Core Auth
APP_ID = fd2c509253239f84db51
ZOSTEL_APP_ID = 5Njb5awMk0dbC7VNnY7Z35tw2yEE1HtA92r9YA1t
NODE_ENV = development
NEXT_ASSET_PREFIX =
NEXT_BASE_PATH =

# API Backend — use production for real data
API_BASE_URL = https://api.io.zo.xyz
API_BASE_URL_ZOSTEL = https://api.zostel.com
API_SOCKET_URL = wss://api.io.zo.xyz

# Sentry (optional)
SENTRY_AUTH_TOKEN =

# Zo House Features — Supabase
# Only needed if working on cafe/housekeeping features
# Ask team lead for credentials
NEXT_PUBLIC_SUPABASE_URL =
NEXT_PUBLIC_SUPABASE_ANON_KEY =

# Razorpay webhook (server-side only — must NOT be NEXT_PUBLIC_)
# Generated in Razorpay Dashboard → Account → Webhooks when registering
# https://zozozo.work/pm/api/cafe/razorpay-webhook for payment.captured +
# payment.failed events.
RAZORPAY_WEBHOOK_SECRET =

# Supabase service role key (server-side only — must NOT be NEXT_PUBLIC_).
# Used by the Razorpay webhook to update cafe_orders while bypassing RLS.
# Keep out of any file that ships to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY =

# Razorpay API credentials (server-side only — must NOT be NEXT_PUBLIC_).
# Used by /pm/api/cafe/create-razorpay-order to create Razorpay Orders for
# the customer ordering flow on /cafezomad/[tableId]. KEY_ID is technically
# public (echoed back to the client to init Checkout) but we don't expose it
# as NEXT_PUBLIC_; the server endpoint returns it in the response payload.
# Live keys: rzp_live_… ; Test keys: rzp_test_…
RAZORPAY_KEY_ID =
RAZORPAY_KEY_SECRET =
