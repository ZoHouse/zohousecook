# Website App — Environment Variables
# Copy this file to .env.local and fill in the values

# Core Auth
APP_ID = c26ea3e427cf42a88a18
NODE_ENV = development
NEXT_ASSET_PREFIX =
NEXT_BASE_PATH =

# API Backend
#   API_BASE_URL           = live Zo API (auth, OTP, existing /profile/me/ writes, everything else).
#   API_BASE_URL_PASSPORT  = optional override for Passport Game of Life v2 reads. Falls back to
#                            API_BASE_URL if unset. Set to the Postman mock URL for Phase 1 dev,
#                            swap to Daya's staging when available, leave unset in prod so prod
#                            traffic naturally falls back to API_BASE_URL.
API_BASE_URL = https://api.io.zo.xyz
API_BASE_URL_PASSPORT =
API_SOCKET_URL = wss://api.io.zo.xyz
WEB_BASE_URL = https://zo.xyz

# Mapbox (for maps)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN =

# Media
MEDIA_BASE_URL = https://proxy.cdn.zo.xyz

