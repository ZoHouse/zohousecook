# Meta WhatsApp Cloud API (graph.facebook.com)
# Get these from developers.facebook.com -> your app -> WhatsApp -> API Setup / App Settings -> Basic
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
# Random string you invent. Paste the SAME string into Meta -> WhatsApp -> Configuration -> Webhook -> Verify Token.
META_VERIFY_TOKEN=zomad-wtf-2026-changeme

# LLM (OpenAI for v0)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage (SQLite — single file, created automatically on first boot)
DB_PATH=./zomad.db

# Server
PORT=8000
