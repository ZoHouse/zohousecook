{
  "name": "ops-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ops-backend",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/ops-backend"],
      "options": {
        "commands": [
          "npx tsc -p apps/ops-backend/tsconfig.app.json --outDir dist/apps/ops-backend",
          "cp apps/ops-backend/package.json dist/apps/ops-backend/package.json",
          "echo 'engine-strict=false' > dist/apps/ops-backend/.npmrc"
        ],
        "parallel": false
      }
    },
    "install-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm install --silent",
        "cwd": "dist/apps/ops-backend"
      },
      "dependsOn": ["build"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "node dist/apps/ops-backend/server.js",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "development": {
          "command": "node dist/apps/ops-backend/server.js",
          "cwd": "{workspaceRoot}"
        },
        "production": {
          "command": "node dist/apps/ops-backend/server.js",
          "cwd": "{workspaceRoot}"
        }
      },
      "dependsOn": ["install-deps"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ops-backend/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/ops-backend/**/*.{ts,tsx,js,jsx}"]
      }
    }
  },
  "tags": []
}
