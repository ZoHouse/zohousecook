# X (Twitter) — OAuth 2.0 user-context (Authorization Code with PKCE).
# Get from developer.x.com → Projects & Apps → your app → "Keys and tokens".
# Required scopes when granting: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# Initial tokens used once on first run, then persisted to .data/db.json.
# Refresh tokens rotate on every refresh, so the value here goes stale —
# the on-disk store is the source of truth from then on.
X_INITIAL_ACCESS_TOKEN=
X_INITIAL_REFRESH_TOKEN=

# Cron auth — only enforced if set. Leave empty for local dev.
CRON_SECRET=

# Optional sub-path deployment
NEXT_BASE_PATH=
NEXT_ASSET_PREFIX=
