{
  "name": "payment",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/payment",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/payment",
        "postcssConfig": "apps/payment/postcss.config.js"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/payment"
        },
        "staging": {},
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "payment:build",
        "dev": true,
        "port": 4205
      },
      "configurations": {
        "development": {
          "buildTarget": "payment:build:development",
          "dev": true
        },
        "staging": {
          "buildTarget": "payment:build:staging",
          "dev": false
        },
        "production": {
          "buildTarget": "payment:build:production",
          "dev": false
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "payment:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/payment/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/payment/**/*.{ts,tsx,js,jsx}"]
      }
    }
  },
  "tags": []
}
