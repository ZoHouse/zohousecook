{
  "family": "mono-front-zo-ops-staging",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "zo-ops",
      "image": "PLACEHOLDER_IMAGE",
      "portMappings": [
        {
          "containerPort": 3000
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mono-front-zo-ops-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "secrets": [
        {
          "name": "REACT_APP_SLACK_BOT_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-zo-ops-staging-secrets-UEhlyB:REACT_APP_SLACK_BOT_TOKEN::"
        },
        {
          "name": "REACT_APP_SLACK_SIGNING_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-zo-ops-staging-secrets-UEhlyB:REACT_APP_SLACK_SIGNING_SECRET::"
        },
        {
          "name": "REACT_APP_API_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-zo-ops-staging-secrets-UEhlyB:REACT_APP_API_URL::"
        },
        {
          "name": "REACT_APP_MAPBOX_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-zo-ops-staging-secrets-UEhlyB:REACT_APP_MAPBOX_TOKEN::"
        }
      ]
    }
  ]
}
