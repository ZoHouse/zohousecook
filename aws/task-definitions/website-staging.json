{
  "family": "mono-front-website-staging",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "website",
      "image": "PLACEHOLDER_IMAGE",
      "portMappings": [
        {
          "containerPort": 3000
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mono-front-website-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "secrets": [
        {
          "name": "APP_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:APP_ID ::"
        },
        {
          "name": "NODE_ENV ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:NODE_ENV ::"
        },
        {
          "name": "NEXT_ASSET_PREFIX ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:NEXT_ASSET_PREFIX ::"
        },
        {
          "name": "NEXT_BASE_PATH ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:NEXT_BASE_PATH ::"
        },
        {
          "name": "API_BASE_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:API_BASE_URL ::"
        },
        {
          "name": "API_SOCKET_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:API_SOCKET_URL ::"
        },
        {
          "name": "WEB_BASE_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:WEB_BASE_URL ::"
        },
        {
          "name": "NFT_AIRDROP_COLLECTION_SLUG ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:NFT_AIRDROP_COLLECTION_SLUG ::"
        },
        {
          "name": "NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN ::"
        },
        {
          "name": "SINGAPORE_EVENT_POA_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:SINGAPORE_EVENT_POA_ID ::"
        },
        {
          "name": "SINGAPORE_OPERATOR_PID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:SINGAPORE_OPERATOR_PID ::"
        },
        {
          "name": "ZOHOUSE_SFO_PID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:ZOHOUSE_SFO_PID ::"
        },
        {
          "name": "CRYPTO_EVENT_PID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:CRYPTO_EVENT_PID ::"
        },
        {
          "name": "MEDIA_BASE_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-website-staging-secrets-LYlWt4:MEDIA_BASE_URL ::"
        }
      ]
    }
  ]
}
