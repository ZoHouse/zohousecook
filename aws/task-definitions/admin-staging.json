{
  "family": "mono-front-admin-staging",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::670664477975:role/mono-front-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "admin",
      "image": "PLACEHOLDER_IMAGE",
      "portMappings": [
        {
          "containerPort": 3000
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mono-front-admin-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "secrets": [
        {
          "name": "APP_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:APP_ID ::"
        },
        {
          "name": "NODE_ENV ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:NODE_ENV ::"
        },
        {
          "name": "NEXT_ASSET_PREFIX ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:NEXT_ASSET_PREFIX ::"
        },
        {
          "name": "NEXT_BASE_PATH ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:NEXT_BASE_PATH ::"
        },
        {
          "name": "API_BASE_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:API_BASE_URL ::"
        },
        {
          "name": "API_SOCKET_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:API_SOCKET_URL ::"
        },
        {
          "name": "ZOSTEL_BASE_WEB_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:ZOSTEL_BASE_WEB_URL ::"
        },
        {
          "name": "WEB_BASE_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:WEB_BASE_URL ::"
        },
        {
          "name": "API_BASE_URL_ZOSTEL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:API_BASE_URL_ZOSTEL ::"
        },
        {
          "name": "ZOSTEL_APP_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:ZOSTEL_APP_ID ::"
        },
        {
          "name": "NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN ::"
        },
        {
          "name": "ZOSTEL_ADMIN_URL ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:ZOSTEL_ADMIN_URL ::"
        },
        {
          "name": "TRIP_OPERATOR_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:TRIP_OPERATOR_ID ::"
        },
        {
          "name": "POA_CONTRACT_ID ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:670664477975:secret:mono-front-admin-staging-secrets-UH0o0D:POA_CONTRACT_ID ::"
        }
      ]
    }
  ]
}
